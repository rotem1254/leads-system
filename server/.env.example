# העתק ל-.env והשלם ערכים (לעולם לא לשתף את הקובץ .env)

SUPABASE_URL=https://xxxx.supabase.co

# מפתח anon מ-Supabase (Settings → API)
SUPABASE_ANON_KEY=

# מומלץ לשרת בפרודקשן: מפתח service_role (Settings → API) — נשמר רק בשרת, לא בדפדפן
# אם מוגדר, יעקוף את מדיניות RLS — מתאים ל-API backend
SUPABASE_SERVICE_ROLE_KEY=

# תואם לאפיון המקורי אם השתמשת בשם SUPABASE_KEY
# SUPABASE_KEY=

# טוקן לניהול לידים (GET/PUT/DELETE) — הזן בלוח הניהול בכניסה
ADMIN_TOKEN=שנה-אותי-למחרוזת-ארוכה-ואקראית

# פורט מקומי (Render מזרים PORT אוטומטית)
# PORT=3000
