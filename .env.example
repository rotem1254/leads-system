# Copy to `.env.local` for Next.js (never commit real secrets)

# --- Supabase (required) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Route Handlers + Auth Admin API (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional ---
# Comma-separated origins for Access-Control-Allow-Origin on POST /api/leads (default: *)
# ALLOWED_ORIGINS=https://landing.example.com,https://www.client-site.com

# Server-only: verbose POST /api/leads diagnostics (token prefix/length only, no secrets). Unset in production.
# DEBUG_LEADS_API=1
